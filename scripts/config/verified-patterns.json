{
  "schema_version": 1,
  "updated": "2026-03-13",
  "patterns": [
    {
      "id": "error-sanitization",
      "anti_pattern": "Raw error.message logging",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S1",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "path-traversal",
      "anti_pattern": "startsWith('..') for path check",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S2",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "toctou-race",
      "anti_pattern": "existsSync before readFileSync",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S3",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "exec-global-flag",
      "anti_pattern": "exec() without /g flag in loops",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S4",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "unsafe-writefile",
      "anti_pattern": "writeFileSync without symlink guard",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S6",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "direct-firestore-write",
      "anti_pattern": "Direct Firestore writes to protected collections",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S5",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "unsafe-shell-interpolation",
      "anti_pattern": "execSync with template literal interpolation",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S7",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "jsonl-parse-no-try-catch",
      "anti_pattern": "JSON.parse on full JSONL file",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S8",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    },
    {
      "id": "path-separator-mismatch",
      "anti_pattern": "filePath.includes('src/') without normalization",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S9",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    },
    {
      "id": "cyclomatic-complexity",
      "anti_pattern": "Functions with CC > 15",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S10",
      "enforcement": "SonarCloud CI",
      "severity": "high"
    },
    {
      "id": "unsafe-gha-interpolation",
      "anti_pattern": "${{ }} in GitHub Actions run: blocks",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S11",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "bare-rename",
      "anti_pattern": "fs.renameSync() without safe wrapper",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S17",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    },
    {
      "id": "path-containment",
      "anti_pattern": "path.resolve() used without containment check",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S18",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "critical"
    },
    {
      "id": "bare-symlink-check",
      "anti_pattern": "Bare lstatSync symlink check",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S13",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    },
    {
      "id": "bare-jsonl-append",
      "anti_pattern": "fs.appendFileSync() on JSONL without lock",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S14",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    },
    {
      "id": "raw-console-error",
      "anti_pattern": "console.error() with raw error objects",
      "positive_pattern_ref": "POSITIVE_PATTERNS.md S16",
      "enforcement": "patterns:check + code-reviewer",
      "severity": "high"
    }
  ],
