#!/bin/sh
# Pre-push hook - Additional gate before pushing to remote
# This blocks pushes if checks fail

# Source shared hook infrastructure (add_exit_trap, is_skipped, require_skip_reason, _shared_init_fnm)
. "$(dirname "$0")/_shared.sh"

# --- Wave 3: Timing infrastructure (D6, D7) ---
HOOK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
CHECKS_TMPFILE=$(mktemp)
add_exit_trap "rm -f '$CHECKS_TMPFILE'"

_shared_init_fnm

# --- SKIP_CHECKS consolidation (mirrors pre-commit pattern) ---
# Map individual SKIP_ env vars to SKIP_CHECKS for is_skipped() usage
for _sk in WARNINGS:warnings PROPAGATION:propagation CC:cc COG_CC:cog-cc TRIGGERS:triggers REVIEWER:reviewer; do
  _var="SKIP_${_sk%%:*}"; _name="${_sk#*:}"
  eval "_val=\${$_var:-}"
  [ "$_val" = "1" ] && SKIP_CHECKS="${SKIP_CHECKS:+$SKIP_CHECKS,}$_name"
done

# Log append-hook-warning output instead of silencing (C7-G5)
HOOK_OUTPUT_LOG="$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.git/hook-output.log"

echo "🚀 Running pre-push checks..."

# ── Wave 0: Escalation gate — block on unacknowledged error-level warnings (D4) ──
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
if [ "${CI:-}" = "true" ]; then
  echo "  ⏭️  Escalation gate skipped (CI environment)"
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then
    CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 ))
  else
    CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 ))
  fi
  echo "escalation-gate|skip|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
else
  ESCALATION_OUTPUT=$(node -e "
    const fs = require('fs');
    const warningsPath = '.claude/hook-warnings.json';
    const ackPath = '.claude/state/hook-warnings-ack.json';
    try {
      if (!fs.existsSync(warningsPath)) process.exit(0);
      const w = JSON.parse(fs.readFileSync(warningsPath, 'utf8'));
      let ack = { acknowledged: {}, lastCleared: null };
      try {
        const parsedAck = JSON.parse(fs.readFileSync(ackPath, 'utf8'));
        if (parsedAck && typeof parsedAck === 'object') {
          ack.acknowledged = parsedAck.acknowledged || {};
          ack.lastCleared = parsedAck.lastCleared || null;
        }
      } catch {}
      const errors = (w.warnings || []).filter(e => {
        if (e.severity !== 'error') return false;
        const entryTime = new Date(e.timestamp).getTime();
        const ackTime = ack.acknowledged[e.type];
        if (ackTime && entryTime <= new Date(ackTime).getTime()) return false;
        if (ack.lastCleared && entryTime <= new Date(ack.lastCleared).getTime()) return false;
        return true;
      });
      if (errors.length > 0) {
        errors.forEach(e => console.error('  ❌ ' + e.type + ': ' + e.message));
        process.exit(1);
      }
    } catch (err) {
      // If warnings file is corrupt, don't block
      process.exit(0);
    }
  " 2>&1)
  GATE_EXIT=$?
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then
    CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 ))
  else
    CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 ))
  fi

  if [ "$GATE_EXIT" -ne 0 ]; then
    echo "❌ PUSH BLOCKED: Unacknowledged error-level warnings" >&2
    echo "$ESCALATION_OUTPUT" >&2
    echo "" >&2
    echo "   Fix the underlying issues, or:" >&2
    echo "   Skip: SKIP_WARNINGS=1 SKIP_REASON=\"...\" git push" >&2

    if is_skipped "warnings"; then
      require_skip_reason "SKIP_WARNINGS=1"
      node scripts/log-override.js --quick --check=escalation-gate --reason="$SKIP_REASON" \
        || echo "⚠️ Override log failed" >&2
      echo "escalation-gate|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    else
      echo "escalation-gate|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
      exit 1
    fi
  else
    echo "  ✅ No unacknowledged error-level warnings"
    echo "escalation-gate|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
fi

# ── Rebase detection — skip code-analysis gates when no content changed ──
_REBASE_ONLY=0
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  _rebase_content_diff=$(git diff --stat @{u} HEAD 2>/dev/null)
  if [ -z "$_rebase_content_diff" ]; then
    _REBASE_ONLY=1
    echo "  ℹ️  Rebase-only push detected (no content changes vs upstream) — skipping code analysis"
  fi
fi

# 1. Tests already run in pre-commit (Quick Win - Session #113)
# Removed duplicate test run - saves 50-60s per push

# 2. Check for circular dependencies (ONLY if app code changed)
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
# Determine base ref with fallback (Qodo bug #3)
_base_ref=""
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  _base_ref="@{u}"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  _base_ref="origin/main"
elif git rev-parse --verify origin/master >/dev/null 2>&1; then
  _base_ref="origin/master"
fi
if [ -z "$_base_ref" ]; then
  # No base ref — run check unconditionally (safer than skipping)
  _app_code_changed="forced"
else
  _app_code_changed=$(git diff --name-only --diff-filter=ACMR "$_base_ref"...HEAD 2>/dev/null | grep -E '^(lib/|components/|app/).*\.(ts|tsx|js|jsx)$' | head -1)
fi
if [ -z "$_app_code_changed" ]; then
  echo "  ⏭️ Circular deps skipped (no app code in push diff)"
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  echo "circular-deps|skip|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
else
  echo "  ▶ Checking for circular dependencies..."
  if ! npm run deps:circular > /dev/null 2>&1; then
    echo "  ❌ Circular dependencies detected"
    npm run deps:circular 2>&1 | tail -10
    echo ""
    echo "  Fix circular dependencies before pushing. Run: npm run deps:circular"
    CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
    if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
    echo "circular-deps|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  fi
  echo "  ✅ No circular dependencies"
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  echo "circular-deps|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
fi

# 3. Pattern compliance on PUSH DIFF ONLY (PR #388 retro — 2x recommended)
# Previously REMOVED due to double-jeopardy (scanning all 14 hardcoded files).
# Re-enabled in diff-only mode: only checks files actually in the push diff.
# This catches patterns in review fix commits that may bypass pre-commit.
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Pattern compliance skipped (rebase-only push, no content changes)"
  echo "pattern-compliance-push|skip|0" >> "$CHECKS_TMPFILE"
else
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
echo "  ▶ Checking pattern compliance (push diff only)..."
set +e
push_diff_files=$(git diff --name-only --diff-filter=ACMR @{u}...HEAD 2>/dev/null | grep -E '\.(js|mjs)$' | head -30)
set -e

if [ -n "${push_diff_files:-}" ]; then
  # Pass files as positional args to check-pattern-compliance.js
  set +e
  pattern_output=$(printf '%s\n' "$push_diff_files" | xargs -r node scripts/check-pattern-compliance.js 2>&1)
  pattern_exit=$?
  set -e
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  if [ "$pattern_exit" -ne 0 ]; then
    echo "  ⚠️ Pattern compliance issues in pushed files:"
    printf '%s\n' "$pattern_output" | grep -E "❌|⚠️|BLOCK|WARN" | head -10
    echo ""
    echo "  Fix issues or run: npm run patterns:check"
    # C2-G1: Extract top 3 affected files for enriched warning
    _pat_files=$(printf '%s\n' "$pattern_output" | grep -oE '📄 [^ ]+' | sed 's/📄 //' | head -3 | tr '\n' ',' | sed 's/,$//')
    node scripts/append-hook-warning.js --hook=pre-push --type=patterns --severity=warning --message="Pattern compliance issues in pushed files" --action="npm run patterns:check" --files="${_pat_files:-unknown}" --pattern="check-pattern-compliance" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: pattern compliance" >&2
    echo "pattern-compliance-push|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ✅ Pattern compliance passed (push diff)"
    echo "pattern-compliance-push|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
else
  echo "  ⏭️ No JS files in push diff"
  echo "pattern-compliance-push|skip|0" >> "$CHECKS_TMPFILE"
fi
fi

# 3b. Code-reviewer gate for script changes (Session #151)
# If scripts/.claude/hooks/.husky/ changed, check if code-reviewer ran this session
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Code-reviewer gate skipped (rebase-only push, no content changes)"
  echo "code-reviewer-gate|skip|0" >> "$CHECKS_TMPFILE"
else
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
echo "  ▶ Checking code-reviewer coverage for script changes..."
set +e
script_changes=$(git diff --name-only --diff-filter=ACMR @{u}...HEAD 2>/dev/null | grep -E '^(scripts/|\.claude/hooks/|\.husky/)' | head -5)
set -e

if [ -n "${script_changes:-}" ]; then
  # Check if code-reviewer was invoked within the last 4 hours (C7-G1)
  reviewer_ran=$(node -e "
    try {
      const lines = require('fs').readFileSync('.claude/state/agent-invocations.jsonl','utf8').trim().split('\\n');
      const cutoff = Date.now() - 4*3600000;
      const ok = lines.some(l => { try { const e = JSON.parse(l); return e.agent === 'code-reviewer' && new Date(e.timestamp).getTime() > cutoff; } catch { return false; } });
      process.stdout.write(ok ? '1' : '0');
    } catch { process.stdout.write('0'); }
  " 2>/dev/null || echo "0")

  if [ "$reviewer_ran" -eq 0 ]; then
    echo "  ⚠️ Script changes detected but code-reviewer not invoked this session"
    echo "  Changed files:"
    printf '%s\n' "$script_changes" | while read -r f; do echo "    - $f"; done
    echo ""
    echo "  Run code-reviewer before pushing script changes."
    echo "  Use: SKIP_REASON=\"reason\" SKIP_REVIEWER=1 git push to bypass (not recommended)"
    if [ "${SKIP_REVIEWER:-}" != "1" ]; then
      CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
      if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
      echo "code-reviewer-gate|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
      exit 1
    fi
    require_skip_reason "SKIP_REVIEWER=1"
    echo "  ⚠️ Bypassed with SKIP_REVIEWER=1"
    node scripts/log-override.js --quick --check=reviewer --reason="$SKIP_REASON" 2>/dev/null || true
    node scripts/append-hook-warning.js --hook=pre-push --type=reviewer --severity=warning --message="Code-reviewer bypassed for script changes" --action="Run code-reviewer agent" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: code-reviewer bypass" >&2
    CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
    if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
    echo "code-reviewer-gate|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ✅ Code-reviewer was invoked for script changes"
    CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
    if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
    echo "code-reviewer-gate|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
else
  echo "  ✅ No script changes (code-reviewer gate skipped)"
  echo "code-reviewer-gate|skip|0" >> "$CHECKS_TMPFILE"
fi
fi

# 3c. Propagation check (Session #185 — 8x recommended across PRs #366-#388)
# Detects functions modified in some files but not propagated to duplicate copies.
# SCOPED: only run if script files are in the push diff.
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Propagation check skipped (rebase-only push, no content changes)"
  echo "propagation|skip|0" >> "$CHECKS_TMPFILE"
else
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
_scripts_in_diff=$(git diff --name-only --diff-filter=ACMR @{u}...HEAD 2>/dev/null | grep -E '^scripts/.*\.js$' | head -1)
if [ -z "$_scripts_in_diff" ]; then
  echo "  ⏭️ Propagation check skipped (no scripts in push diff)"
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  echo "propagation|skip|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
else
echo "  ▶ Running propagation check..."
set +e
prop_output=$(node scripts/check-propagation.js --blocking 2>&1)
prop_exit=$?
set -e
CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
if [ "$prop_exit" -ne 0 ]; then
  printf '%s\n' "$prop_output"
  echo ""
  echo "  ⚠️ Propagation misses detected — review and fix before pushing"
  echo "  Use: SKIP_REASON=\"reason\" SKIP_PROPAGATION=1 git push to bypass"
  if [ "${SKIP_PROPAGATION:-}" != "1" ]; then
    echo "propagation|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  fi
  require_skip_reason "SKIP_PROPAGATION=1"
  echo "  ⚠️ Bypassed with SKIP_PROPAGATION=1"
  node scripts/log-override.js --quick --check=propagation --reason="$SKIP_REASON" 2>/dev/null || true
  # C2-G1: Extract top 3 affected files and pattern name for enriched warning
  _prop_files=$(printf '%s\n' "$prop_output" | grep -E '^\s+- ' | sed 's/^\s*- //' | head -3 | tr '\n' ',' | sed 's/,$//')
  _prop_pattern=$(printf '%s\n' "$prop_output" | grep -oE 'Pattern: [^ ]+' | head -1 | sed 's/Pattern: //')
  node scripts/append-hook-warning.js --hook=pre-push --type=propagation --severity=warning --message="Propagation check bypassed" --action="Review duplicate functions" --files="${_prop_files:-unknown}" --pattern="${_prop_pattern:-propagation}" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: propagation bypass" >&2
  echo "propagation|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
elif echo "$prop_output" | grep -q "⚠️"; then
  printf '%s\n' "$prop_output"
  _prop_files=$(printf '%s\n' "$prop_output" | grep -E '^\s+- ' | sed 's/^\s*- //' | head -3 | tr '\n' ',' | sed 's/,$//')
  _prop_pattern=$(printf '%s\n' "$prop_output" | grep -oE 'Pattern: [^ ]+' | head -1 | sed 's/Pattern: //')
  node scripts/append-hook-warning.js --hook=pre-push --type=propagation --severity=info --message="Propagation warnings found in pushed code" --action="Review duplicate functions" --files="${_prop_files:-unknown}" --pattern="${_prop_pattern:-propagation}" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: propagation warnings" >&2
  echo "propagation|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
elif echo "$prop_output" | grep -q "✅"; then
  printf '%s\n' "$prop_output"
  echo "propagation|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
else
  echo "propagation|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
fi
fi
fi

# 3d. Hook test suite (Session #185 — gated on .claude/hooks/ changes)
# Only runs when hook files are modified in the push diff.
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Hook test suite skipped (rebase-only push, no content changes)"
  echo "hook-tests|skip|0" >> "$CHECKS_TMPFILE"
else
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
set +e
hook_changes=$(git diff --name-only --diff-filter=ACMR @{u}...HEAD 2>/dev/null | grep -E '^\.claude/hooks/.*\.js$' | head -10)
set -e

if [ -n "${hook_changes:-}" ]; then
  echo "  ▶ Running hook test suite (hook files changed)..."
  set +e
  hook_test_output=$(npm run hooks:test 2>&1)
  hook_test_exit=$?
  set -e
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  if [ "$hook_test_exit" -ne 0 ]; then
    echo "  ❌ Hook tests failed"
    printf '%s\n' "$hook_test_output" | grep -E "✗|FAIL|Failed" | head -10
    echo ""
    echo "  Fix hook tests before pushing. Run: npm run hooks:test"
    node scripts/append-hook-warning.js --hook=pre-push --type=hook-tests --severity=warning --message="Hook tests failed" --action="npm run hooks:test" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: hook tests" >&2
    echo "hook-tests|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  fi
  echo "  ✅ Hook tests passed"
  echo "hook-tests|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
else
  echo "  ✅ No hook changes (hook test gate skipped)"
  echo "hook-tests|skip|0" >> "$CHECKS_TMPFILE"
fi
fi

# 4. Security pattern check (diff-only mode: only flag violations in ADDED lines)
# Hook-quality fix: Previously scanned entire files, catching pre-existing violations
# that weren't introduced by the current commits. Now uses --diff-only to only check
# lines that were actually added in the push.
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Security pattern check skipped (rebase-only push, no content changes)"
  echo "security-check|skip|0" >> "$CHECKS_TMPFILE"
else
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
echo "  ▶ Running security pattern check (diff-only)..."
set +e
# Filter to .js/.ts content only using diff headers (C6-G4)
security_diff=$(git diff --diff-filter=ACMR @{u}...HEAD -U0 2>/dev/null | awk '
  /^diff --git / { f=$NF; sub(/^b\//, "", f); js=(f ~ /\.(js|jsx|ts|tsx|mjs)$/) }
  /^\+\+\+/ { next }
  js && /^\+[^+]/ { print }
')
diff_exit=$?
set -e

if [ "$diff_exit" -ne 0 ] || [ -z "${security_diff:-}" ]; then
  echo "  ⚠️ No upstream or no added lines detected; skipping security scan"
  echo "security-check|skip|0" >> "$CHECKS_TMPFILE"
else
  # Write added lines to temp file for scanning
  # Use .js extension so security-check.js applies JS/TS patterns to the content
  # Note: mktemp --suffix is GNU-only; use mktemp + mv for POSIX portability
  SEC_TMPFILE_BASE=$(mktemp) || { echo "  ❌ Failed to create temp file"; exit 1; }
  add_exit_trap 'rm -f "$SEC_TMPFILE_BASE" "$SEC_TMPFILE"'
  SEC_TMPFILE="${SEC_TMPFILE_BASE}.js"
  mv "$SEC_TMPFILE_BASE" "$SEC_TMPFILE" || { echo "  ❌ Failed to rename temp file"; exit 1; }
  printf '%s\n' "$security_diff" > "$SEC_TMPFILE"

  set +e
  out=$(node scripts/security-check.js --file "$SEC_TMPFILE" --blocking 2>&1)
  code=$?
  set -e

  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  if [ "$code" -ne 0 ]; then
    echo "  ❌ Security violations found in NEW code"
    printf '%s\n' "$out" | grep -e "CRITICAL" -e "HIGH" -e "file:" | head -15
    echo ""
    echo "  Fix security issues in your new code before pushing."
    echo "security-check|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  elif echo "$out" | grep -q "MEDIUM\|LOW"; then
    echo "  ⚠️ Security warnings in new code (not blocking) - review recommended"
    node scripts/append-hook-warning.js --hook=pre-push --type=security --severity=warning --message="Security warnings (MEDIUM/LOW) found in pushed code" --action="npm run security:check" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: security warnings" >&2
    echo "security-check|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ✅ Security check passed (new code only)"
    echo "security-check|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
fi
fi

# 5. Parallel type + complexity checks (C8-G1)
# Run tsc, cyclomatic CC, and cognitive CC concurrently for ~5-8s savings
if [ "$_REBASE_ONLY" = "1" ]; then
  echo "  ⏭️ Type + complexity checks skipped (rebase-only push, no content changes)"
  echo "tsc|skip|0" >> "$CHECKS_TMPFILE"
  echo "cyclomatic-cc|skip|0" >> "$CHECKS_TMPFILE"
  echo "cognitive-cc|skip|0" >> "$CHECKS_TMPFILE"
else
echo "  ▶ Running type + complexity checks in parallel..."

# Handle skip flags before launching parallel jobs
_cyc_skip=0; _cog_skip=0
if [ "${SKIP_CC:-}" = "1" ]; then
  require_skip_reason "SKIP_CC=1"
  echo "  ⚠️ CC check skipped (SKIP_CC=1)"
  node scripts/log-override.js --quick --check=cc --reason="$SKIP_REASON" 2>/dev/null || true
  _cyc_skip=1
  echo "cyclomatic-cc|skip|0" >> "$CHECKS_TMPFILE"
fi
if [ "${SKIP_COG_CC:-}" = "1" ]; then
  require_skip_reason "SKIP_COG_CC=1"
  echo "  ⚠️ Cognitive CC check skipped (SKIP_COG_CC=1)"
  node scripts/log-override.js --quick --check=cognitive-cc --reason="$SKIP_REASON" 2>/dev/null || true
  _cog_skip=1
  echo "cognitive-cc|skip|0" >> "$CHECKS_TMPFILE"
fi

# Create tmpfiles for parallel results
_TSC_OUT=$(mktemp); _CYC_OUT=$(mktemp); _COG_OUT=$(mktemp)
add_exit_trap 'rm -f "$_TSC_OUT" "$_CYC_OUT" "$_COG_OUT" "${_TSC_OUT}.rc" "${_CYC_OUT}.rc" "${_COG_OUT}.rc"'

# Timing for parallel checks — capture start time for each
_TSC_START_NS=$(date +%s%N 2>/dev/null || date +%s)

# 5a. Type check (background, ONLY if TS/TSX files in push diff)
# Determine base ref with fallback (Qodo bug #3)
_tsc_base_ref=""
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  _tsc_base_ref="@{u}"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  _tsc_base_ref="origin/main"
elif git rev-parse --verify origin/master >/dev/null 2>&1; then
  _tsc_base_ref="origin/master"
fi
if [ -z "$_tsc_base_ref" ]; then
  # No base ref — run check unconditionally (safer than skipping)
  _ts_in_diff="forced"
else
  _ts_in_diff=$(git diff --name-only --diff-filter=ACMR "$_tsc_base_ref"...HEAD 2>/dev/null | grep -E '\.(ts|tsx)$' | head -1)
fi
_tsc_skip=0
if [ -z "$_ts_in_diff" ]; then
  echo "  ⏭️ Type check skipped (no TS files in push diff)"
  echo "0" > "${_TSC_OUT}.rc"
  _tsc_skip=1
  echo "tsc|skip|0" >> "$CHECKS_TMPFILE"
else
  (npx tsc --noEmit > "$_TSC_OUT" 2>&1; echo $? > "${_TSC_OUT}.rc") &
fi

# 5b. Cyclomatic complexity via check-cyclomatic-cc.js (background, unless skipped)
# Uses baseline from known-debt-baseline.json to suppress known debt
if [ "$_cyc_skip" -eq 0 ] && [ -f scripts/check-cyclomatic-cc.js ]; then
  (node scripts/check-cyclomatic-cc.js > "$_CYC_OUT" 2>&1; echo $? > "${_CYC_OUT}.rc") &
fi

# 5c. Cognitive complexity (background, unless skipped)
if [ "$_cog_skip" -eq 0 ] && [ -f scripts/check-cc.js ]; then
  (node scripts/check-cc.js > "$_COG_OUT" 2>&1; echo $? > "${_COG_OUT}.rc") &
fi

# Wait for all background jobs
wait
_PARALLEL_END_NS=$(date +%s%N 2>/dev/null || date +%s)
if [ ${#_TSC_START_NS} -gt 10 ]; then _PARALLEL_DURATION_MS=$(( (_PARALLEL_END_NS - _TSC_START_NS) / 1000000 )); else _PARALLEL_DURATION_MS=$(( (_PARALLEL_END_NS - _TSC_START_NS) * 1000 )); fi

# --- Process results ---

# 5a result: type check (skip if no TS files in diff)
if [ "$_tsc_skip" -eq 0 ]; then
  _tsc_rc=$(cat "${_TSC_OUT}.rc" 2>/dev/null || echo "1")
  if [ "$_tsc_rc" -ne 0 ]; then
    echo "  ❌ Type check failed"
    tail -10 "$_TSC_OUT"
    echo ""
    echo "  Fix type errors before pushing. Run: npx tsc --noEmit"
    echo "type-check|fail|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  fi
  echo "  ✅ Type check passed"
  echo "type-check|pass|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
fi

# 5b result: cyclomatic complexity (via check-cyclomatic-cc.js with baseline)
if [ "$_cyc_skip" -eq 0 ] && [ -f scripts/check-cyclomatic-cc.js ]; then
  _cyc_rc=$(cat "${_CYC_OUT}.rc" 2>/dev/null || echo "0")
  if [ "$_cyc_rc" -eq 1 ]; then
    echo "  ❌ Cyclomatic complexity regressions (CC >15) in pushed files:"
    grep -E "FAIL|CC=" "$_CYC_OUT" | head -10
    echo ""
    echo "  Extract helper functions to reduce complexity before pushing."
    echo "  Override: SKIP_REASON=\"reason\" SKIP_CC=1 git push"
    echo "cyclomatic-cc|fail|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  elif [ "$_cyc_rc" -eq 0 ]; then
    echo "  ✅ Cyclomatic complexity passed (CC ≤15, baseline-aware)"
    echo "cyclomatic-cc|pass|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ⚠️ Cyclomatic CC check errored (exit $_cyc_rc), continuing"
    echo "cyclomatic-cc|warn|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
elif [ "$_cyc_skip" -eq 0 ]; then
  echo "cyclomatic-cc|skip|0" >> "$CHECKS_TMPFILE"
fi

# 5c result: cognitive complexity
if [ "$_cog_skip" -eq 0 ] && [ -f scripts/check-cc.js ]; then
  _cog_rc=$(cat "${_COG_OUT}.rc" 2>/dev/null || echo "2")
  if [ "$_cog_rc" -eq 1 ]; then
    echo "  ❌ Cognitive complexity violations (CC >15) in pushed files:"
    grep -E "CC=" "$_COG_OUT" | head -10
    echo ""
    echo "  Extract helper functions to reduce complexity before pushing."
    echo "  Override: SKIP_REASON=\"reason\" SKIP_COG_CC=1 git push"
    echo "cognitive-cc|fail|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  elif [ "$_cog_rc" -eq 0 ]; then
    echo "  ✅ Cognitive complexity passed (CC ≤15)"
    echo "cognitive-cc|pass|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ⚠️ Cognitive CC check errored (exit $_cog_rc), continuing"
    echo "cognitive-cc|warn|${_PARALLEL_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
elif [ "$_cog_skip" -eq 0 ]; then
  echo "cognitive-cc|skip|0" >> "$CHECKS_TMPFILE"
fi
fi

# 6. Security audit (non-blocking warning, ~3-8s)
# Checks for high/critical vulnerabilities in dependencies
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
echo "  ▶ Running security audit..."
# Review #214: Disable errexit for npm audit (returns non-zero for vulnerabilities)
# Review #322: Preserve and restore original errexit state
had_errexit=0
case $- in
  *e*) had_errexit=1 ;;
esac
set +e
audit_output=$(npm audit --audit-level=high 2>&1)
audit_exit=$?
if [ "$had_errexit" -eq 1 ]; then
  set -e
fi
CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
if [ "$audit_exit" -ne 0 ]; then
  # Check if it's a real vulnerability (exit code 1) vs network error
  if echo "$audit_output" | grep -q "vulnerabilities"; then
    echo "  ⚠️ Security vulnerabilities found (not blocking - run: npm audit)"
    echo "$audit_output" | grep -E "high|critical|vulnerabilities" | head -5
    node scripts/append-hook-warning.js --hook=pre-push --type=audit --severity=warning --message="npm audit found security vulnerabilities" --action="npm audit" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: npm audit" >&2
    echo "npm-audit|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  else
    echo "  ⚠️ npm audit check skipped (network or registry issue)"
    node scripts/append-hook-warning.js --hook=pre-push --type=network-error --severity=info \
      --message="npm audit skipped — network unavailable" \
      --action="Check network connectivity and retry" \
      || echo "⚠️ npm audit skipped — network unavailable" >&2
    echo "npm-audit|skip|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
  fi
else
  echo "  ✅ No high/critical vulnerabilities"
  echo "npm-audit|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
fi

# 7. Event-based trigger checker (blocking for security, warning for others)
# Checks: security_audit (files with auth/token/etc.), consolidation, skill_validation
CHECK_START_NS=$(date +%s%N 2>/dev/null || date +%s)
echo "  ▶ Checking event-based triggers..."
if [ "${SKIP_TRIGGERS:-}" = "1" ]; then
  require_skip_reason "SKIP_TRIGGERS=1"
  echo "  ⚠️ Triggers skipped (SKIP_TRIGGERS=1)"
  # Log the override for audit trail with reason
  node scripts/log-override.js --check=triggers --reason="$SKIP_REASON" 2>/dev/null || true
  echo "triggers|skip|0" >> "$CHECKS_TMPFILE"
else
  triggers_output=$(npm run triggers:check 2>&1)
  triggers_exit=$?
  CHECK_END_NS=$(date +%s%N 2>/dev/null || date +%s)
  if [ ${#CHECK_START_NS} -gt 10 ]; then CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) / 1000000 )); else CHECK_DURATION_MS=$(( (CHECK_END_NS - CHECK_START_NS) * 1000 )); fi
  if [ "$triggers_exit" -eq 1 ]; then
    echo "  ❌ Blocking trigger(s) activated"
    printf '%s\n' "$triggers_output" | grep -E "^🚫|^❌|^   Action:|^   Files:" | head -20
    echo ""
    echo "  Complete required actions or use: SKIP_REASON=\"reason\" SKIP_TRIGGERS=1 git push"
    echo "triggers|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  elif [ "$triggers_exit" -eq 0 ]; then
    # Show warnings but don't block
    if echo "$triggers_output" | grep -q "⚠️"; then
      printf '%s\n' "$triggers_output" | grep -E "^⚠️|^   Action:" | head -10
      # Extract first warning message for the alert
      first_warning=$(printf '%s\n' "$triggers_output" | grep "^⚠️" | head -1 | sed 's/^⚠️ *//')
      # Review #322: Normalize warning message to single line to prevent parsing issues
      first_warning_one_line=$(printf '%s' "$first_warning" | tr '\n\r' '  ' | sed 's/[[:space:]]\{1,\}/ /g; s/^ *//; s/ *$//')
      # Review #214: Only create alert if we have a non-empty message
      if [ -n "$first_warning_one_line" ]; then
        node scripts/append-hook-warning.js --hook=pre-push --type=trigger --severity=info --message="$first_warning_one_line" >> "$HOOK_OUTPUT_LOG" 2>&1 || echo "⚠️ Warning write failed: trigger warning" >&2
      fi
      echo "triggers|warn|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    else
      echo "  ✅ No blocking triggers"
      echo "triggers|pass|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    fi
  else
    # Fail closed: unexpected exit code means something went wrong
    echo "  ❌ Triggers check failed (exit $triggers_exit)"
    printf '%s\n' "$triggers_output" | tail -20
    echo ""
    echo "  Fix the triggers checker error or use: SKIP_REASON=\"reason\" SKIP_TRIGGERS=1 git push"
    echo "triggers|fail|${CHECK_DURATION_MS}" >> "$CHECKS_TMPFILE"
    exit 1
  fi
fi

# --- End-of-hook summary + hook-runs.jsonl (Wave 3: D6, D7, D11, D12, D29) ---
generate_hook_summary "Pre-push" "$CHECKS_TMPFILE" 2

# Enhanced report with scope + remediation (Session #226)
node scripts/hook-report.js "Pre-push" "$CHECKS_TMPFILE" 2>&1 || echo "⚠️ hook-report.js failed (non-blocking)" >&2

# Write hook-runs.jsonl (D6, D20, D21) — TOTAL_MS set by generate_hook_summary
write_hook_runs_jsonl "pre-push" "$CHECKS_TMPFILE" "$TOTAL_MS"

echo ""
echo "✅ All pre-push checks passed - push allowed"
