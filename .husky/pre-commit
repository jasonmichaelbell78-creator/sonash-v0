#!/bin/sh
# Pre-commit hook - AUTOMATED GATE (not optional documentation)
# This blocks commits if checks fail

# Log all output to .git/hook-output.log for debugging
# (hook stderr is often invisible in CI/agent contexts like Claude Code)
# Note: Husky v9 runs hooks with `sh -e`, so must be POSIX-compatible.
# Cannot use bash process substitution >() since sh doesn't support it.
# Simple redirect to log file; caller can read the log after.
HOOK_OUTPUT_LOG="$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.git/hook-output.log"
exec 3>&2  # save original stderr for non-fatal warnings (PR creep, etc.)
exec > "$HOOK_OUTPUT_LOG" 2>&1

# Display log on failure so developers see what went wrong (Gemini review #379)
# Uses EXIT_TRAP_CHAIN via add_exit_trap (defined below) to coexist with temp file cleanup

# POSIX-safe EXIT trap chaining — appends cleanup commands without overwriting prior traps
# Uses a shell variable to accumulate trap commands (avoids fragile trap -p parsing)
add_exit_trap() {
  EXIT_TRAP_CHAIN="${EXIT_TRAP_CHAIN:+$EXIT_TRAP_CHAIN; }$1"
  trap "$EXIT_TRAP_CHAIN" EXIT
}

# Display log on failure so developers see what went wrong (Gemini review #379)
# Capture exit code before chain runs; display log to stderr on failure
add_exit_trap 'HOOK_EXIT=$?; if [ "$HOOK_EXIT" -ne 0 ] && [ -f "$HOOK_OUTPUT_LOG" ]; then exec 1>/dev/null; printf "\n--- PRE-COMMIT HOOK FAILED ---\n" >&2; cat "$HOOK_OUTPUT_LOG" >&2; printf "--- END OF LOGS ---\n" >&2; fi'

# --- SKIP_CHECKS consolidation ---
# Single variable: SKIP_CHECKS="cross-doc,patterns" SKIP_REASON="reason" git commit ...
# Check if a named check should be skipped
is_skipped() {
  case ",$SKIP_CHECKS," in *",$1,"*) return 0 ;; esac
  return 1
}

# Backward compat: map individual SKIP_ vars to SKIP_CHECKS
for _sk in PATTERN_CHECK:patterns AUDIT_VALIDATION:audit TESTS:tests CROSS_DOC_CHECK:cross-doc DOC_INDEX_CHECK:doc-index DOC_HEADER_CHECK:doc-header DEBT_VALIDATION:debt; do
  _var="SKIP_${_sk%%:*}"; _name="${_sk#*:}"
  eval "_val=\${$_var:-}"
  [ "$_val" = "1" ] && SKIP_CHECKS="${SKIP_CHECKS:+$SKIP_CHECKS,}$_name"
done

# Shared guard: any SKIP_ override requires SKIP_REASON (Session #162)
require_skip_reason() {
  if [ -z "${SKIP_REASON:-}" ]; then
    echo "  ❌ SKIP_REASON is required when overriding checks"
    echo "  Usage: SKIP_REASON=\"your reason\" $1 git commit ..."
    echo "  The audit trail is useless without a reason."
    exit 1
  fi
  # Reject multi-line reasons (prevents JSONL/log injection) — POSIX-safe (no grep -P)
  cr="$(printf '\r')"
  if [ "$(printf '%s' "$SKIP_REASON" | wc -l | tr -d ' ')" -gt 1 ] || printf '%s' "$SKIP_REASON" | grep -q "$cr"; then
    echo "  ❌ SKIP_REASON must be a single line (no CR/LF characters)"
    exit 1
  fi
  # Reject control characters (prevents log injection) — POSIX-safe
  if printf '%s' "$SKIP_REASON" | LC_ALL=C grep -q '[[:cntrl:]]'; then
    echo "  ❌ SKIP_REASON must not contain control characters"
    exit 1
  fi
  # Enforce max length to prevent DoS via oversized reasons
  skip_len=${#SKIP_REASON}
  if [ "$skip_len" -gt 500 ]; then
    echo "  ❌ SKIP_REASON must be <= 500 characters (got $skip_len)"
    exit 1
  fi
  # Validate minimum length to prevent meaningless skip reasons like "x" or "test"
  if [ "$skip_len" -lt 10 ]; then
    echo "  ❌ SKIP_REASON must be at least 10 characters (got $skip_len)"
    echo "  Provide a meaningful reason for the audit trail."
    exit 1
  fi
}

# Validate skip reason once at the top if any checks are being skipped
if [ -n "${SKIP_CHECKS:-}" ]; then
  require_skip_reason "SKIP_CHECKS=\"$SKIP_CHECKS\""
fi

# --- PR Creep Guard (Session #201, fixed #202) ---
# Warn at 10 commits, strongly warn at 20, block at 25 (with override)
# Detect default branch dynamically — remote first (PRs target remote), then local fallback.
# NB: DEFAULT_BRANCH is passed to git merge-base, which resolves "origin/main" as a
# remote tracking ref (not a local branch named origin/main).
BRANCH_NAME="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
if [ -n "$BRANCH_NAME" ] && [ "$BRANCH_NAME" != "main" ] && [ "$BRANCH_NAME" != "master" ] && [ "$BRANCH_NAME" != "HEAD" ]; then
  DEFAULT_BRANCH=""
  if git show-ref --verify --quiet refs/remotes/origin/main 2>/dev/null; then
    DEFAULT_BRANCH="origin/main"
  elif git show-ref --verify --quiet refs/remotes/origin/master 2>/dev/null; then
    DEFAULT_BRANCH="origin/master"
  elif git show-ref --verify --quiet refs/heads/main 2>/dev/null; then
    DEFAULT_BRANCH="main"
  elif git show-ref --verify --quiet refs/heads/master 2>/dev/null; then
    DEFAULT_BRANCH="master"
  fi
  MERGE_BASE=""
  if [ -n "$DEFAULT_BRANCH" ]; then
    MERGE_BASE="$(git merge-base "$DEFAULT_BRANCH" "$BRANCH_NAME" 2>/dev/null || echo "")"
  else
    echo "  PR creep guard: no main/master ref found, skipping commit count check" >&3
  fi
  unset DEFAULT_BRANCH
  if [ -n "$MERGE_BASE" ]; then
    COMMIT_COUNT="$(git rev-list --count "$MERGE_BASE"..HEAD 2>/dev/null || echo "0")"
    PR_CREEP_WARN=10
    PR_CREEP_STRONG=20
    PR_CREEP_BLOCK=25
    if [ "$COMMIT_COUNT" -ge "$PR_CREEP_BLOCK" ] && ! is_skipped "pr-creep"; then
      echo "  🚫 PR CREEP GUARD: $COMMIT_COUNT commits on this branch (limit: $PR_CREEP_BLOCK)"
      echo "  Consider creating a PR before adding more commits."
      echo "  Override: SKIP_CHECKS=\"pr-creep\" SKIP_REASON=\"branch needs more work before PR\" git commit ..."
      exit 1
    elif [ "$COMMIT_COUNT" -ge "$PR_CREEP_STRONG" ]; then
      echo "  ⚠️  PR CREEP WARNING: $COMMIT_COUNT commits on this branch — PR strongly recommended" >&3
    elif [ "$COMMIT_COUNT" -ge "$PR_CREEP_WARN" ]; then
      echo "  📋 Branch has $COMMIT_COUNT commits — consider creating a PR soon" >&3
    fi
  fi
fi

# Initialize fnm so node/npm/npx are available in this shell context
if command -v fnm > /dev/null 2>&1; then
  FNM_ENV="$(fnm env --shell bash 2>/dev/null || true)"
  if [ -z "$FNM_ENV" ]; then
    echo "  ❌ fnm detected but failed to initialize; cannot reliably run Node-based checks" >&2
    exit 1
  fi
  eval "$FNM_ENV"
fi

echo "🔍 Running pre-commit checks..."

# --- Wave 0: Secrets scan (fast, ~1s) ---
echo "  ▶ Scanning for secrets (gitleaks)..."
if command -v gitleaks > /dev/null 2>&1; then
  gitleaks_exit=0
  gitleaks protect --staged -c .gitleaks.toml --no-banner || gitleaks_exit=$?
  if [ "$gitleaks_exit" -eq 1 ]; then
    echo "  ❌ Secrets detected in staged files"
    echo ""
    echo "  Remove secrets before committing. Run: gitleaks detect --source ."
    echo "  If false positive, add to .gitleaks.toml allowlist."
    exit 1
  elif [ "$gitleaks_exit" -ne 0 ]; then
    echo "  ❌ gitleaks encountered an error (exit $gitleaks_exit) — scan could not be completed" >&2
    echo "  Fix gitleaks/config before committing. Override: SKIP_CHECKS=\"gitleaks\" SKIP_REASON=\"reason\" git commit ..." >&2
    exit "$gitleaks_exit"
  else
    echo "  ✅ No secrets detected"
  fi
else
  echo "  ⏭️ gitleaks not installed (install: winget install Gitleaks.Gitleaks)"
fi

# --- Wave 1: ESLint + Tests in parallel ---
# These are the two slowest checks (~15s each). Run concurrently for ~50% time savings.
# Pattern compliance runs sequentially after (it's fast, ~0.1s).

ESLINT_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
add_exit_trap 'rm -f "$ESLINT_TMPFILE" 2>/dev/null'
TEST_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
add_exit_trap 'rm -f "$TEST_TMPFILE" 2>/dev/null'

# --- Start ESLint in background ---
echo "  ▶ Running ESLint..."
(npm run lint > "$ESLINT_TMPFILE" 2>&1; echo $? > "${ESLINT_TMPFILE}.exit") &
PID_LINT=$!

# --- Determine if tests should run, start in background if so ---
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
RUN_TESTS=0
SKIP_TEST_REASON=""
PID_TEST=""

if is_skipped tests; then
  node scripts/log-override.js --quick --check=tests --reason="$SKIP_REASON" 2>/dev/null || true
  SKIP_TEST_REASON="SKIP_CHECKS"
elif printf '%s\n' "$STAGED_FILES" | grep -Eq '^(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock|tsconfig.*\.json|next\.config\.(js|mjs|ts)|\.husky/|\.github/)'; then
  RUN_TESTS=1
  echo "  ▶ Running tests (config changes detected)..."
  (npm test > "$TEST_TMPFILE" 2>&1; echo $? > "${TEST_TMPFILE}.exit") &
  PID_TEST=$!
else
  DOC_DIRS="docs/|\.claude/"
  DOC_FILES="DOCUMENTATION_INDEX|SESSION_CONTEXT|ROADMAP|CLAUDE|ARCHITECTURE|DEVELOPMENT|AI_WORKFLOW"
  DOC_EXTS="md|mdx|txt|png|jpg|jpeg|gif|svg|jsonl"
  DOC_PATTERN="^(${DOC_DIRS}).*|(${DOC_FILES})|.*\.(${DOC_EXTS})$"
  NON_DOC_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -Ev "$DOC_PATTERN" || true)
  if [ -z "$NON_DOC_FILES" ]; then
    SKIP_TEST_REASON="doc-only"
  else
    RUN_TESTS=1
    echo "  ▶ Running tests..."
    (npm test > "$TEST_TMPFILE" 2>&1; echo $? > "${TEST_TMPFILE}.exit") &
    PID_TEST=$!
  fi
fi

# --- Wait for ESLint ---
wait $PID_LINT 2>/dev/null || true
LINT_EXIT=$(cat "${ESLINT_TMPFILE}.exit" 2>/dev/null || echo "1")
rm -f "${ESLINT_TMPFILE}.exit" 2>/dev/null
if [ "$LINT_EXIT" -ne 0 ]; then
  echo "  ❌ ESLint has errors"
  tail -20 "$ESLINT_TMPFILE"
  echo ""
  echo "  Fix errors before committing. Run: npm run lint"
  # Kill test if still running
  [ -n "$PID_TEST" ] && kill $PID_TEST 2>/dev/null || true
  exit 1
fi
echo "  ✅ ESLint passed"

# --- Wait for tests ---
if [ "$RUN_TESTS" -eq 1 ] && [ -n "$PID_TEST" ]; then
  wait $PID_TEST 2>/dev/null || true
  TEST_EXIT=$(cat "${TEST_TMPFILE}.exit" 2>/dev/null || echo "1")
  rm -f "${TEST_TMPFILE}.exit" 2>/dev/null
  if [ "$TEST_EXIT" -ne 0 ]; then
    echo "  ❌ Tests failed"
    tail -10 "$TEST_TMPFILE"
    echo ""
    echo "  Fix tests before committing. Run: npm test"
    exit 1
  fi
  echo "  ✅ Tests passed"
elif [ -n "$SKIP_TEST_REASON" ]; then
  echo "  ⏭️ Skipping tests ($SKIP_TEST_REASON)"
fi


# 2. Auto-format staged files with lint-staged (Prettier)
# Automatically formats staged files - no manual intervention needed
echo "  ▶ Running lint-staged (auto-format)..."
# Check if lint-staged is installed as devDependency (security: --no-install prevents supply chain attacks)
if npm list lint-staged --depth=0 > /dev/null 2>&1; then
  if ! npx --no-install lint-staged --no-stash; then
    echo "  ❌ Lint-staged failed"
    exit 1
  fi
  echo "  ✅ Lint-staged passed (files formatted)"
else
  echo "  ⚠️ lint-staged not installed - run 'npm ci' to enable auto-formatting"
  echo "  ⏭️ Skipping lint-staged (devDependency missing from node_modules)"
fi

# 3. Run pattern compliance check on staged files (blocks on critical violations)
# Override with: SKIP_CHECKS="patterns" SKIP_REASON="reason" git commit ...
if is_skipped patterns; then
  node scripts/log-override.js --quick --check=pattern-compliance --reason="$SKIP_REASON" 2>/dev/null || true
  echo "  ⏭️ Skipping pattern compliance (skipped via SKIP_CHECKS)"
else
  echo "  ▶ Running pattern compliance..."
  PATTERN_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
  add_exit_trap 'rm -f "$PATTERN_TMPFILE" 2>/dev/null'
  node scripts/check-pattern-compliance.js --staged > "$PATTERN_TMPFILE" 2>&1
  PATTERN_EXIT=$?
  if [ "$PATTERN_EXIT" -eq 1 ]; then
    echo "  ❌ Pattern compliance: critical violations found"
    cat "$PATTERN_TMPFILE"
    echo ""
    echo "  Fix critical violations before committing."
    exit 1
  elif [ "$PATTERN_EXIT" -eq 2 ]; then
    echo "  ⚠️ Pattern compliance check errored (non-blocking)"
    tail -5 "$PATTERN_TMPFILE"
  else
    # Exit 0: no critical violations (may have warnings)
    if grep -q "⚠️" "$PATTERN_TMPFILE" 2>/dev/null; then
      echo "  ✅ Pattern compliance passed (with warnings)"
      cat "$PATTERN_TMPFILE"
    else
      echo "  ✅ Pattern compliance passed"
    fi
  fi
fi

# 3b. Propagation check WARNING (non-blocking early heads-up)
# Pattern 13 (Fix-One-Audit-All): warn if staged files have pattern gaps
# that exist in sibling files. Pre-push already blocks; this is a heads-up.
echo "  ▶ Running propagation check (staged, warning only)..."
set +e
prop_staged_output=$(node scripts/check-propagation.js --staged 2>&1)
prop_staged_exit=$?
set -e
if [ "$prop_staged_exit" -ne 0 ] || echo "$prop_staged_output" | grep -q "⚠️"; then
  _prop_fd="2"
  if { : >&3; } 2>/dev/null; then _prop_fd="3"; fi
  echo "  ⚠️ Propagation check: pattern gaps detected in staged area (not blocking)" >&${_prop_fd}
  printf '%s\n' "$prop_staged_output" | grep "⚠️" | head -5 >&${_prop_fd}
  node scripts/append-hook-warning.js --hook=pre-commit --type=propagation --severity=info --message="Propagation pattern gaps in staged files" --action="Review sibling files for same pattern" 2>/dev/null || true
fi

# 4. Audit file S0/S1 validation (BLOCKING - Session #98)
# Validates that S0/S1 findings have proper verification_steps
# Override with: SKIP_CHECKS="audit" SKIP_REASON="reason" git commit ...
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
if ! is_skipped audit; then
  STAGED_AUDIT_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E "docs/audits/.*\.jsonl$" || true)
  if [ -n "$STAGED_AUDIT_FILES" ]; then
    echo "  ▶ Validating audit S0/S1 compliance..."
    # POSIX-compatible: Write to temp file, read with while loop
    # Review #204: Pipe creates subshell where variable changes don't propagate
    # Chain with existing EXIT trap instead of overwriting
    AUDIT_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
    add_exit_trap 'rm -f "$AUDIT_TMPFILE" 2>/dev/null'
    echo "$STAGED_AUDIT_FILES" > "$AUDIT_TMPFILE"
    AUDIT_FAILED=0
    while IFS= read -r audit_file || [ -n "$audit_file" ]; do
      [ -z "$audit_file" ] && continue
      audit_out="$(node scripts/validate-audit.js "$audit_file" --strict-s0s1 2>&1)"
      audit_code=$?
      if [ "$audit_code" -ne 0 ]; then
        AUDIT_FAILED=1
        echo "  ❌ S0/S1 validation failed: $audit_file"
        printf '%s\n' "$audit_out" | grep -E "^   ❌|BLOCKING" | head -5
      fi
    done < "$AUDIT_TMPFILE"
    rm -f "$AUDIT_TMPFILE"
    if [ "$AUDIT_FAILED" -eq 1 ]; then
      echo ""
      echo "  Fix S0/S1 violations or downgrade severity. Run:"
      echo "    node scripts/validate-audit.js <file> --strict-s0s1"
      echo "  Override: SKIP_CHECKS=\"audit\" SKIP_REASON=\"reason\" git commit ..."
      exit 1
    fi
    echo "  ✅ Audit S0/S1 validation passed"
  fi
else
  node scripts/log-override.js --quick --check=audit-s0s1 --reason="$SKIP_REASON" 2>/dev/null || true
  echo "  ⏭️ Skipping audit validation (skipped via SKIP_CHECKS)"
fi

# 5. CANON schema validation (non-blocking warning, ~1s)
# Validates CANON files when audit output is staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
if printf '%s\n' "$STAGED_FILES" | grep -q "docs/reviews/.*\.jsonl"; then
  echo "  ▶ Validating CANON schema..."
  if npm run validate:canon > /dev/null 2>&1; then
    echo "  ✅ CANON validation passed"
  else
    echo "  ⚠️ CANON validation issues found (not blocking - run: npm run validate:canon)"
    node scripts/append-hook-warning.js --hook=pre-commit --type=canon --severity=warning --message="CANON validation issues found" --action="npm run validate:canon" 2>/dev/null || true
  fi
fi

# 6. Skill configuration validation (non-blocking, when skill files modified)
if printf '%s\n' "$STAGED_FILES" | grep -Eq '\.(claude)/(skills|commands)/.*\.md$'; then
  echo "  ▶ Validating skill configurations..."
  skills_output=$(npm run skills:validate 2>&1)
  if echo "$skills_output" | grep -q "❌ ERROR"; then
    echo "  ⚠️ Skill validation issues found (not blocking - run: npm run skills:validate)"
    printf '%s\n' "$skills_output" | grep -E "^📄|^   ❌" | head -10
    node scripts/append-hook-warning.js --hook=pre-commit --type=skill --severity=warning --message="Skill validation issues found" --action="npm run skills:validate" 2>/dev/null || true
  else
    echo "  ✅ Skill validation passed"
  fi
fi

# 7. Cross-document dependency check (BLOCKING - Session #69)
# Override with: SKIP_CHECKS="cross-doc" SKIP_REASON="reason" git commit ...
if is_skipped cross-doc; then
  node scripts/log-override.js --quick --check=cross-doc-deps --reason="$SKIP_REASON" 2>/dev/null || true
  echo "  ⏭️ Skipping cross-doc dependency check (skipped via SKIP_CHECKS)"
else
  echo "  ▶ Checking cross-document dependencies..."
  if ! node scripts/check-cross-doc-deps.js --trivial; then
    echo "  ❌ Cross-document dependency check failed"
    echo ""
    echo "  Fix dependencies before committing. Run: npm run crossdoc:check"
    echo "  Override: SKIP_CHECKS=\"cross-doc\" SKIP_REASON=\"reason\" git commit ..."
    exit 1
  fi
  echo "  ✅ Cross-document dependencies satisfied"
fi

# 8. Documentation Index auto-update (AUTO-FIX - Session #103, fixed #149)
# Override with: SKIP_CHECKS="doc-index" SKIP_REASON="reason" git commit ...
if is_skipped doc-index; then
  node scripts/log-override.js --quick --check=doc-index --reason="$SKIP_REASON" 2>/dev/null || true
  echo "  ⏭️ Skipping doc index check (skipped via SKIP_CHECKS)"
else
  CHANGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ADM | grep -E '\.md$' || true)
  if [ -n "$CHANGED_MD_FILES" ]; then
    echo "  ▶ Auto-updating documentation index..."
    # Atomic fail-safe: backup before generation, restore on failure (Finding 1)
    cp DOCUMENTATION_INDEX.md DOCUMENTATION_INDEX.md.bak 2>/dev/null || true
    if npm run docs:index > /dev/null 2>&1; then
      # Format after regeneration so CI Prettier check passes
      npx prettier --write DOCUMENTATION_INDEX.md > /dev/null 2>&1 || echo "  ⚠️ Prettier formatting failed for DOCUMENTATION_INDEX.md (non-blocking)"
      git add DOCUMENTATION_INDEX.md
      echo "  ✅ Documentation index updated and staged"
    else
      # Restore original on failure — no partial/broken index gets committed
      if [ -f DOCUMENTATION_INDEX.md.bak ]; then
        mv DOCUMENTATION_INDEX.md.bak DOCUMENTATION_INDEX.md
      fi
      echo "  ⚠️ Documentation index generation failed, original preserved (non-blocking)"
    fi
    rm -f DOCUMENTATION_INDEX.md.bak 2>/dev/null || true
  fi
fi

# 9. Document header validation for NEW docs (BLOCKING - Session #115)
# Override with: SKIP_CHECKS="doc-header" SKIP_REASON="reason" git commit ...
if is_skipped doc-header; then
  node scripts/log-override.js --quick --check=doc-header --reason="$SKIP_REASON" 2>/dev/null || true
else
  NEW_MD_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '\.md$' || true)
  if [ -n "$NEW_MD_FILES" ]; then
    echo "  ▶ Validating new document headers..."
    if ! node scripts/check-doc-headers.js; then
      exit 1
    fi
    echo "  ✅ Document headers validated"
  fi
fi

# 10. Agent compliance check (non-blocking, single-line summary)
echo "  ▶ Checking agent compliance..."
if [ -n "${STRICT_AGENT_CHECK:-}" ]; then
  if ! node scripts/check-agent-compliance.js --strict 2>&1; then
    exit 1
  fi
else
  agent_output=$(node scripts/check-agent-compliance.js 2>&1) || true
  if echo "$agent_output" | grep -q "⚠️"; then
    echo "  ⚠️ Agent compliance: code changed without agent review"
    node scripts/append-hook-warning.js --hook=pre-commit --type=agent --severity=warning --message="Agent compliance warnings - code changed without agent review" --action="Use code-reviewer agent for modified code" 2>/dev/null || true
  fi
fi

# 11. Technical debt schema validation (BLOCKING - TDMS Phase 7)
# Override with: SKIP_CHECKS="debt" SKIP_REASON="reason" git commit ...
if is_skipped debt; then
  node scripts/log-override.js --quick --check=debt-schema --reason="$SKIP_REASON" 2>/dev/null || true
else
  if printf '%s\n' "$STAGED_FILES" | grep -q "docs/technical-debt/MASTER_DEBT.jsonl"; then
    echo "  ▶ Validating technical debt schema (changed lines)..."
    if ! node scripts/debt/validate-schema.js --staged-only > /dev/null 2>&1; then
      echo "  ❌ Technical debt schema validation failed"
      node scripts/debt/validate-schema.js --staged-only 2>&1 | tail -10
      echo ""
      echo "  Fix schema issues before committing. Run:"
      echo "    node scripts/debt/validate-schema.js --staged-only"
      echo "  Override: SKIP_CHECKS=\"debt\" SKIP_REASON=\"reason\" git commit ..."
      exit 1
    fi
    echo "  ✅ Technical debt schema passed"
  fi
fi

# 12. JSONL→MD sync validation (WARNING - D84/D85)
# Warns when planning JSONL changed but no MD files are staged.
# Full content comparison deferred to batch gate (formatter rewrites MD after generation).
# Override with: SKIP_CHECKS="jsonl-sync" SKIP_REASON="reason" git commit ...
if is_skipped jsonl-sync; then
  node scripts/log-override.js --quick --check=jsonl-sync --reason="$SKIP_REASON" 2>/dev/null || true
else
  if printf '%s\n' "$STAGED_FILES" | grep -qE '\.planning/.*\.jsonl$'; then
    if ! printf '%s\n' "$STAGED_FILES" | grep -qE '\.planning/.*\.(md|MD)$'; then
      echo "  ⚠️ Planning JSONL changed but no MD files staged — did you forget to regenerate?" >&3
      echo "    node scripts/planning/generate-discovery-record.js" >&3
      echo "    node scripts/planning/generate-decisions.js" >&3
      node scripts/append-hook-warning.js --hook=pre-commit --type=jsonl-sync --severity=warning --message="Planning JSONL changed without MD regeneration" --action="Run generation scripts" 2>/dev/null || true
    else
      echo "  ✅ Planning JSONL + MD both staged"
    fi
  fi
fi

# 13. Test coverage warning for new scripts (non-blocking, D#63/#69)
# Warns when new .js files in covered directories have no corresponding test file
STAGED_JS_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js)$' || true)
if [ -n "$STAGED_JS_FILES" ]; then
  NEW_JS_FILES=$(git diff --cached --name-only --diff-filter=A 2>/dev/null | grep -E '\.(js)$' || true)
  if [ -n "$NEW_JS_FILES" ]; then
    _test_warn_fd="2"
    if { : >&3; } 2>/dev/null; then _test_warn_fd="3"; fi
    printf '%s\n' "$NEW_JS_FILES" | while IFS= read -r js_file || [ -n "$js_file" ]; do
      [ -z "$js_file" ] && continue
      # Only check covered directories: scripts/, .claude/hooks/, .claude/skills/*/scripts/
      case "$js_file" in
        scripts/*|.claude/hooks/*|.claude/skills/*/scripts/*) ;;
        *) continue ;;
      esac
      # Skip test files, dist output, and __tests__ directories
      case "$js_file" in
        *.test.js|*__tests__/*|*/dist/*|*/fixtures/*) continue ;;
      esac
      # Check if a corresponding test file exists
      base_name=$(basename "$js_file" .js)
      has_test=0
      # Search common test locations
      for test_loc in \
        "tests/scripts/${base_name}.test.ts" \
        "tests/scripts/${base_name}.test.js" \
        "tests/${base_name}.test.ts" \
        "tests/${base_name}.test.js"; do
        if [ -f "$test_loc" ]; then has_test=1; break; fi
      done
      # Also check co-located __tests__ directories
      dir_name=$(dirname "$js_file")
      if [ -f "${dir_name}/__tests__/${base_name}.test.js" ] || [ -f "${dir_name}/__tests__/${base_name}.test.ts" ]; then
        has_test=1
      fi
      if [ "$has_test" -eq 0 ]; then
        echo "  ⚠ New script $js_file has no test file" >&${_test_warn_fd}
      fi
    done
  fi
fi

echo ""
echo "✅ All pre-commit checks passed - commit allowed"
