{
  "_note": "Firebase, GitHub, Context7 are auto-discovered by Claude Code plugins. Only non-auto-discovered MCP servers need entries here.",
  "mcpServers": {
    "memory": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-memory"]
    },
    "sonarcloud": {
      "command": "node",
      "args": ["scripts/mcp/sonarcloud-server.js"],
      "env": {
        "SONAR_TOKEN": "${SONAR_TOKEN}",
        "SONAR_URL": "https://sonarcloud.io"
      }
    }
  }
}
