{"id":260,"date":"2026-02-07","title":"PR #346 Audit Trigger Reset - Round 1 Qodo + SonarCloud + CI","source":"sonarcloud+qodo+ci","pr":346,"patterns":["root-cause","prevention"],"fixed":8,"deferred":0,"rejected":0,"critical":2,"major":3,"minor":3,"trivial":0,"total":11,"learnings":["Qodo PR Code Suggestions + SonarCloud Security Hotspots + CI","Root cause: `seed-commit-log.js` used `execSync(cmd)` string form","Prevention: Always use `execFileSync(\"binary\", [args])`","Root cause: `reset-audit-triggers.js` used unbounded regex quantifiers","Prevention: Always add `\\n` to negated character classes in table parsing","Root cause: `check-session-gaps.js` used `{}` for groupBySession","Prevention: Use `Object.create(null)` for any user-influenced map keys"]}
