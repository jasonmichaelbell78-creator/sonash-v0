# Ephemeral session state - do not track
# These files are generated per-session and should not be committed
*.state.json
!task-pr-review-*.state.json
handoff.json
pending-reviews.json
commit-log.jsonl

# Locale sync backups (temporary, created during cross-locale merges)
.work-backup-*/

# Keep this .gitignore tracked
!.gitignore
