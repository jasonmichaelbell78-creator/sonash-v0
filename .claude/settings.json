{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Agent",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(cp *)",
      "Bash(gh *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(SKIP_* *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(for *)",
      "Bash(if *)",
      "WebSearch",
      "WebFetch",
      "Skill(update-config)",
      "mcp__sonarcloud",
      "mcp__memory"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push origin main)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "enableAllProjectMcpServers": true,
  "disabledMcpjsonServers": [],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/session-start.js"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/check-mcp-servers.js",
            "statusMessage": "Checking MCP availability...",
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/check-remote-session-context.js",
            "statusMessage": "Checking remote branches for session context...",
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/global/gsd-check-update.js",
            "statusMessage": "Checking for GSD updates...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/compact-restore.js",
            "statusMessage": "Restoring context after compaction..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/block-push-to-main.js",
            "statusMessage": "Checking push target..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/pre-commit-agent-compliance.js",
            "statusMessage": "Checking agent compliance..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/pre-compaction-save.js $ARGUMENTS",
            "statusMessage": "Saving state before compaction..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?i)write$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=write bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating write operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)edit$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=edit bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating edit operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)multiedit$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=multiedit bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating multiedit operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)read$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-read-handler.js $ARGUMENTS",
            "statusMessage": "Processing read operation..."
          }
        ]
      },
      {
        "matcher": "^(askuserquestion|AskUserQuestion|ASKUSERQUESTION)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/decision-save-prompt.js $ARGUMENTS",
            "statusMessage": "Checking decision documentation..."
          }
        ]
      },
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/commit-tracker.js $ARGUMENTS",
            "statusMessage": "Tracking commits...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(task|Task|TASK|agent|Agent|AGENT)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/track-agent-invocation.js $ARGUMENTS",
            "statusMessage": "Tracking agent invocation..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/user-prompt-handler.js",
            "statusMessage": "Processing user prompt..."
          }
        ]
      }
    ],
    "Notification": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/global/statusline.js"
  },
  "enabledPlugins": {
    "episodic-memory@superpowers-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "superpowers-chrome@superpowers-marketplace": true
  }
}
