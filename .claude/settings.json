{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(*)",
      "WebSearch",
      "WebFetch",
      "Skill",
      "mcp__sonarcloud",
      "mcp__memory",
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_episodic-memory_episodic-memory__search"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push origin main)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_GLOB_TIMEOUT_SECONDS": "60"
  },
  "enableAllProjectMcpServers": true,
  "disabledMcpjsonServers": [],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/session-start.js"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/check-mcp-servers.js",
            "statusMessage": "Checking MCP availability...",
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/check-remote-session-context.js",
            "statusMessage": "Checking remote branches for session context...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/compact-restore.js",
            "statusMessage": "Restoring context after compaction..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/global/gsd-check-update.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/block-push-to-main.js",
            "statusMessage": "Checking push target..."
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/pre-commit-agent-compliance.js",
            "statusMessage": "Checking agent compliance..."
          },
          {
            "type": "command",
            "if": "Bash(firebase deploy *)|Bash(npx firebase deploy *)|Bash(npm run deploy *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/deploy-safeguard.js",
            "statusMessage": "Running pre-deploy checks..."
          }
        ]
      },
      {
        "matcher": "^(?i)write$",
        "hooks": [
          {
            "type": "command",
            "if": "Write(.env.local.encrypted)",
            "command": "bash -c 'echo \"[env-guard] BLOCKED: .env.local.encrypted must not be overwritten by AI agents\" >&2 && bash .claude/hooks/ensure-fnm.sh node scripts/append-hook-warning.js --hook=pre-tool --type=env-guard --severity=error --message=\"Blocked write to .env.local.encrypted\" 2>/dev/null; exit 2'",
            "statusMessage": "Checking env file protection..."
          }
        ]
      },
      {
        "matcher": "^(?i)(write|edit)$",
        "hooks": [
          {
            "type": "command",
            "if": "Write(.claude/settings.json)|Edit(.claude/settings.json)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/settings-guardian.js",
            "statusMessage": "Validating settings.json integrity..."
          }
        ]
      },
      {
        "matcher": "^(?i)(write|edit)$",
        "hooks": [
          {
            "type": "command",
            "if": "Write(**/firestore.rules)|Edit(**/firestore.rules)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/firestore-rules-guard.js",
            "statusMessage": "Checking firestore rules integrity..."
          }
        ]
      },
      {
        "matcher": "^(?i)read$",
        "hooks": [
          {
            "type": "command",
            "if": "Read(*.jsonl)|Read(*.log)|Read(*.csv)|Read(*.ndjson)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/large-file-gate.js",
            "statusMessage": "Checking file size..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/pre-compaction-save.js $ARGUMENTS",
            "statusMessage": "Saving state before compaction..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?i)write$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=write bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating write operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)edit$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=edit bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating edit operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)multiedit$",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_TOOL=multiedit bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-write-validator.js $ARGUMENTS",
            "statusMessage": "Validating multiedit operation..."
          }
        ]
      },
      {
        "matcher": "^(?i)read$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/post-read-handler.js $ARGUMENTS",
            "statusMessage": "Processing read operation..."
          }
        ]
      },
      {
        "matcher": "^(askuserquestion|AskUserQuestion|ASKUSERQUESTION)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/decision-save-prompt.js $ARGUMENTS",
            "statusMessage": "Checking decision documentation..."
          }
        ]
      },
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)|Bash(git cherry-pick *)|Bash(git merge *)|Bash(git revert *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/commit-tracker.js $ARGUMENTS",
            "statusMessage": "Tracking commits...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm test *)|Bash(npm test)|Bash(npx vitest *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/test-tracker.js",
            "statusMessage": "Tracking test results...",
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^(task|Task|TASK|agent|Agent|AGENT)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/track-agent-invocation.js",
            "statusMessage": "Tracking agent invocation..."
          }
        ]
      },
      {
        "matcher": "^(?i)(write|edit)$",
        "hooks": [
          {
            "type": "command",
            "if": "Write(CLAUDE.md)|Edit(CLAUDE.md)|Write(.claude/settings.json)|Edit(.claude/settings.json)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/governance-logger.js",
            "statusMessage": "Logging governance change...",
            "continueOnError": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/user-prompt-handler.js",
            "statusMessage": "Processing user prompt..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -d \"Claude Code needs your attention\" ntfy.sh/sonash-claude",
            "continueOnError": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "^(?i)bash$",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm run build *)|Bash(npm test *)|Bash(npx tsc *)|Bash(npm run lint *)",
            "command": "bash .claude/hooks/ensure-fnm.sh node .claude/hooks/loop-detector.js",
            "statusMessage": "Checking for error loops...",
            "continueOnError": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "./tools/statusline/sonash-statusline-v3.exe",
    "padding": 2
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "superpowers-chrome@superpowers-marketplace": true
  }
}
