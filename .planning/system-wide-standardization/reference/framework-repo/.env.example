# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values
# .env is gitignored and safe for secrets
# =============================================================================

# -----------------------------------------------------------------------------
# MCP Server Tokens (for Claude Code integrations)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=your_github_pat_here

# SonarCloud Token
# Create at: https://sonarcloud.io/account/security
SONAR_TOKEN=your_sonarcloud_token_here

# Context7 API Key (optional - for library documentation)
# Get from: https://context7.com
CONTEXT7_API_KEY=your_context7_key_here
