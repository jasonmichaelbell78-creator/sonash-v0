#!/bin/sh
# Pre-commit hook - AUTOMATED GATE (not optional documentation)
# This blocks commits if checks fail

# Log all output to .git/hook-output.log for debugging
# (hook stderr is often invisible in CI/agent contexts like Claude Code)
# Note: Husky v9 runs hooks with `sh -e`, so must be POSIX-compatible.
# Cannot use bash process substitution >() since sh doesn't support it.
HOOK_OUTPUT_LOG="$(git rev-parse --show-toplevel 2>/dev/null || echo .)/.git/hook-output.log"
exec > "$HOOK_OUTPUT_LOG" 2>&1

# POSIX-safe EXIT trap chaining — appends cleanup commands without overwriting prior traps
add_exit_trap() {
  EXIT_TRAP_CHAIN="${EXIT_TRAP_CHAIN:+$EXIT_TRAP_CHAIN; }$1"
  trap "$EXIT_TRAP_CHAIN" EXIT
}

# Display log on failure so developers see what went wrong
add_exit_trap 'HOOK_EXIT=$?; if [ "$HOOK_EXIT" -ne 0 ] && [ -f "$HOOK_OUTPUT_LOG" ]; then exec 1>/dev/null; printf "\n--- PRE-COMMIT HOOK FAILED ---\n" >&2; cat "$HOOK_OUTPUT_LOG" >&2; printf "--- END OF LOGS ---\n" >&2; fi'

# --- SKIP_CHECKS consolidation ---
# Single variable: SKIP_CHECKS="patterns,tests" SKIP_REASON="reason" git commit ...
is_skipped() {
  case ",$SKIP_CHECKS," in *",$1,"*) return 0 ;; esac
  return 1
}

# Shared guard: any SKIP_ override requires SKIP_REASON
require_skip_reason() {
  if [ -z "${SKIP_REASON:-}" ]; then
    echo "  ❌ SKIP_REASON is required when overriding checks"
    echo "  Usage: SKIP_REASON=\"your reason\" $1 git commit ..."
    echo "  The audit trail is useless without a reason."
    exit 1
  fi
  # Reject multi-line reasons (prevents JSONL/log injection) — POSIX-safe
  cr="$(printf '\r')"
  if [ "$(printf '%s' "$SKIP_REASON" | wc -l | tr -d ' ')" -gt 0 ] || printf '%s' "$SKIP_REASON" | grep -q "$cr"; then
    echo "  ❌ SKIP_REASON must be a single line (no CR/LF characters)"
    exit 1
  fi
  # Reject control characters (prevents log injection)
  if printf '%s' "$SKIP_REASON" | LC_ALL=C grep -q '[[:cntrl:]]'; then
    echo "  ❌ SKIP_REASON must not contain control characters"
    exit 1
  fi
  skip_len=${#SKIP_REASON}
  if [ "$skip_len" -gt 500 ]; then
    echo "  ❌ SKIP_REASON must be <= 500 characters (got $skip_len)"
    exit 1
  fi
  if [ "$skip_len" -lt 10 ]; then
    echo "  ❌ SKIP_REASON must be at least 10 characters (got $skip_len)"
    echo "  Provide a meaningful reason for the audit trail."
    exit 1
  fi
}

# Validate skip reason once at the top if any checks are being skipped
if [ -n "${SKIP_CHECKS:-}" ]; then
  require_skip_reason "SKIP_CHECKS=\"$SKIP_CHECKS\""
fi

echo "🔍 Running pre-commit checks..."

# --- Wave 1: ESLint + Tests in parallel ---
ESLINT_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
add_exit_trap 'rm -f "$ESLINT_TMPFILE" 2>/dev/null'
TEST_TMPFILE="$(mktemp)" || { echo "  ❌ Failed to create temp file"; exit 1; }
add_exit_trap 'rm -f "$TEST_TMPFILE" 2>/dev/null'

# --- Start ESLint in background ---
echo "  ▶ Running ESLint..."
(npm run lint > "$ESLINT_TMPFILE" 2>&1; echo $? > "${ESLINT_TMPFILE}.exit") &
PID_LINT=$!

# --- Determine if tests should run, start in background if so ---
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
RUN_TESTS=0
SKIP_TEST_REASON=""
PID_TEST=""

if is_skipped tests; then
  SKIP_TEST_REASON="SKIP_CHECKS"
elif printf '%s\n' "$STAGED_FILES" | grep -Eq '^(package\.json|package-lock\.json|pnpm-lock\.yaml|yarn\.lock|tsconfig.*\.json|\.husky/|\.github/)'; then
  RUN_TESTS=1
  echo "  ▶ Running tests (config changes detected)..."
  (npm test > "$TEST_TMPFILE" 2>&1; echo $? > "${TEST_TMPFILE}.exit") &
  PID_TEST=$!
else
  DOC_DIRS="docs/|\.claude/"
  DOC_FILES="DOCUMENTATION_INDEX|SESSION_CONTEXT|ROADMAP|CLAUDE|ARCHITECTURE|DEVELOPMENT"
  DOC_EXTS="md|mdx|txt|png|jpg|jpeg|gif|svg|jsonl"
  DOC_PATTERN="^(${DOC_DIRS}).*|(${DOC_FILES})|.*\.(${DOC_EXTS})$"
  NON_DOC_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -Ev "$DOC_PATTERN" || true)
  if [ -z "$NON_DOC_FILES" ]; then
    SKIP_TEST_REASON="doc-only"
  else
    RUN_TESTS=1
    echo "  ▶ Running tests..."
    (npm test > "$TEST_TMPFILE" 2>&1; echo $? > "${TEST_TMPFILE}.exit") &
    PID_TEST=$!
  fi
fi

# --- Wait for ESLint ---
wait $PID_LINT 2>/dev/null || true
LINT_EXIT=$(cat "${ESLINT_TMPFILE}.exit" 2>/dev/null || echo "1")
rm -f "${ESLINT_TMPFILE}.exit" 2>/dev/null
if [ "$LINT_EXIT" -ne 0 ]; then
  echo "  ❌ ESLint has errors"
  tail -20 "$ESLINT_TMPFILE"
  echo ""
  echo "  Fix errors before committing. Run: npm run lint"
  [ -n "$PID_TEST" ] && kill $PID_TEST 2>/dev/null || true
  exit 1
fi
echo "  ✅ ESLint passed"

# --- Wait for tests ---
if [ "$RUN_TESTS" -eq 1 ] && [ -n "$PID_TEST" ]; then
  wait $PID_TEST 2>/dev/null || true
  TEST_EXIT=$(cat "${TEST_TMPFILE}.exit" 2>/dev/null || echo "1")
  rm -f "${TEST_TMPFILE}.exit" 2>/dev/null
  if [ "$TEST_EXIT" -ne 0 ]; then
    echo "  ❌ Tests failed"
    tail -10 "$TEST_TMPFILE"
    echo ""
    echo "  Fix tests before committing. Run: npm test"
    exit 1
  fi
  echo "  ✅ Tests passed"
elif [ -n "$SKIP_TEST_REASON" ]; then
  echo "  ⏭️ Skipping tests ($SKIP_TEST_REASON)"
fi

# --- Wave 2: Auto-format staged files with lint-staged (Prettier) ---
echo "  ▶ Running lint-staged (auto-format)..."
if npm list lint-staged --depth=0 > /dev/null 2>&1; then
  if ! npx --no-install lint-staged; then
    # lint-staged git backup can fail on rebased/squashed branches — non-blocking if formatting is clean
    if npx prettier --check . > /dev/null 2>&1; then
      echo "  ⚠️ Lint-staged git error (formatting is clean, continuing)"
    else
      echo "  ❌ Lint-staged failed"
      exit 1
    fi
  fi
  echo "  ✅ Lint-staged passed (files formatted)"
else
  echo "  ⚠️ lint-staged not installed - run 'npm ci' to enable auto-formatting"
  echo "  ⏭️ Skipping lint-staged (devDependency missing from node_modules)"
fi

# --- Wave 3: Complexity check (fast, ~0.1s) ---
echo "  ▶ Checking for circular dependencies..."
if ! npm run deps:circular > /dev/null 2>&1; then
  echo "  ❌ Circular dependencies detected"
  npm run deps:circular 2>&1 | tail -10
  echo ""
  echo "  Fix circular dependencies before committing."
  exit 1
fi
echo "  ✅ No circular dependencies"

echo ""
echo "✅ All pre-commit checks passed - commit allowed"
