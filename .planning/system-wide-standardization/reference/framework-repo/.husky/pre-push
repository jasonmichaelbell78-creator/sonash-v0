#!/bin/sh
# Pre-push hook - Additional gate before pushing to remote
# This blocks pushes if checks fail

# Shared guard: any SKIP_ override requires SKIP_REASON
require_skip_reason() {
  if [ -z "${SKIP_REASON:-}" ]; then
    echo "  ❌ SKIP_REASON is required when overriding checks"
    echo "  Usage: SKIP_REASON=\"your reason\" $1 git push ..."
    echo "  The audit trail is useless without a reason."
    exit 1
  fi
  cr="$(printf '\r')"
  if [ "$(printf '%s' "$SKIP_REASON" | wc -l | tr -d ' ')" -gt 0 ] || printf '%s' "$SKIP_REASON" | grep -q "$cr"; then
    echo "  ❌ SKIP_REASON must be a single line (no CR/LF characters)"
    exit 1
  fi
  if printf '%s' "$SKIP_REASON" | LC_ALL=C grep -q '[[:cntrl:]]'; then
    echo "  ❌ SKIP_REASON must not contain control characters"
    exit 1
  fi
  skip_len=${#SKIP_REASON}
  if [ "$skip_len" -gt 500 ]; then
    echo "  ❌ SKIP_REASON must be <= 500 characters (got $skip_len)"
    exit 1
  fi
  if [ "$skip_len" -lt 10 ]; then
    echo "  ❌ SKIP_REASON must be at least 10 characters (got $skip_len)"
    echo "  Provide a meaningful reason for the audit trail."
    exit 1
  fi
}

echo "🚀 Running pre-push checks..."

# Resolve upstream ref (fall back to origin/main for branches without upstream tracking)
UPSTREAM=$(git rev-parse --abbrev-ref @{u} 2>/dev/null || echo "origin/main")

# 1. Check for circular dependencies (blocking - architectural integrity)
echo "  ▶ Checking for circular dependencies..."
if ! npm run deps:circular > /dev/null 2>&1; then
  echo "  ❌ Circular dependencies detected"
  npm run deps:circular 2>&1 | tail -10
  echo ""
  echo "  Fix circular dependencies before pushing. Run: npm run deps:circular"
  exit 1
fi
echo "  ✅ No circular dependencies"

# 2. Type check
echo "  ▶ Running type check..."
if ! npx tsc --noEmit > /dev/null 2>&1; then
  echo "  ❌ Type check failed"
  npx tsc --noEmit 2>&1 | tail -10
  echo ""
  echo "  Fix type errors before pushing. Run: npx tsc --noEmit"
  exit 1
fi
echo "  ✅ Type check passed"

# 3. Security audit (non-blocking warning)
echo "  ▶ Running security audit..."
had_errexit=0
case $- in
  *e*) had_errexit=1 ;;
esac
set +e
audit_output=$(npm audit --audit-level=high 2>&1)
audit_exit=$?
if [ "$had_errexit" -eq 1 ]; then
  set -e
fi
if [ "$audit_exit" -ne 0 ]; then
  if echo "$audit_output" | grep -q "vulnerabilities"; then
    echo "  ⚠️ Security vulnerabilities found (not blocking - run: npm audit)"
    echo "$audit_output" | grep -E "high|critical|vulnerabilities" | head -5
  else
    echo "  ⚠️ npm audit check skipped (network or registry issue)"
  fi
else
  echo "  ✅ No high/critical vulnerabilities"
fi

# 4. Code-reviewer gate for script changes
echo "  ▶ Checking code-reviewer coverage for script changes..."
set +e
script_changes=$(git diff --name-only --diff-filter=ACMR $UPSTREAM...HEAD 2>/dev/null | grep -E '^(scripts/|\.claude/hooks/|\.husky/)' | head -5)
set -e

if [ -n "${script_changes:-}" ]; then
  reviewer_ran=0
  if [ -f ".claude/state/agent-invocations.jsonl" ]; then
    if grep -q '"code-reviewer"' .claude/state/agent-invocations.jsonl 2>/dev/null; then
      reviewer_ran=1
    fi
  fi

  if [ "$reviewer_ran" -eq 0 ]; then
    echo "  ⚠️ Script changes detected but code-reviewer not invoked this session"
    echo "  Changed files:"
    printf '%s\n' "$script_changes" | while read -r f; do echo "    - $f"; done
    echo ""
    echo "  Run code-reviewer before pushing script changes."
    echo "  Use: SKIP_REASON=\"reason\" SKIP_REVIEWER=1 git push to bypass (not recommended)"
    if [ "${SKIP_REVIEWER:-}" != "1" ]; then
      exit 1
    fi
    require_skip_reason "SKIP_REVIEWER=1"
    echo "  ⚠️ Bypassed with SKIP_REVIEWER=1"
  else
    echo "  ✅ Code-reviewer was invoked for script changes"
  fi
else
  echo "  ✅ No script changes (code-reviewer gate skipped)"
fi

# 5. Hook test suite (gated on .claude/hooks/ changes)
set +e
hook_changes=$(git diff --name-only --diff-filter=ACMR $UPSTREAM...HEAD 2>/dev/null | grep -E '^\.claude/hooks/.*\.js$' | head -10)
set -e

if [ -n "${hook_changes:-}" ]; then
  echo "  ▶ Running hook test suite (hook files changed)..."
  set +e
  hook_test_output=$(npm run hooks:test 2>&1)
  hook_test_exit=$?
  set -e
  if [ "$hook_test_exit" -ne 0 ]; then
    echo "  ❌ Hook tests failed"
    printf '%s\n' "$hook_test_output" | grep -E "✗|FAIL|Failed" | head -10
    echo ""
    echo "  Fix hook tests before pushing. Run: npm run hooks:test"
    exit 1
  fi
  echo "  ✅ Hook tests passed"
else
  echo "  ✅ No hook changes (hook test gate skipped)"
fi

echo ""
echo "✅ All pre-push checks passed - push allowed"
