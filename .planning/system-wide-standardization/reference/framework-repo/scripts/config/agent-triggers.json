{
  "agentTriggers": [
    {
      "pattern": { "source": "\\.(ts|tsx|js|jsx)$", "flags": "" },
      "agent": "code-reviewer",
      "description": "Code review for TypeScript/JavaScript changes",
      "excludePaths": [
        {
          "source": "(?:^|\\/)(?:__tests__|node_modules)(?:\\/|$)|\\.(?:test|spec)\\.",
          "flags": ""
        }
      ]
    },
    {
      "pattern": { "source": "\\.md$", "flags": "" },
      "agent": "doc-reviewer",
      "description": "Documentation review for Markdown changes",
      "excludePaths": [{ "source": "(?:^|\\/)(?:node_modules|archive)(?:\\/|$)", "flags": "" }]
    }
  ],
  "reviewChangeThreshold": 5
}
