{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "eslint-plugin-framework/**/*.ts",
    "eslint-plugin-framework/**/*.js",
    "src/**/*"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
